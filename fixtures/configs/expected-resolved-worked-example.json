{
  "topology": "option_a",
  "worktree": {
    "root": "../.agents-worktrees",
    "name_template": "{pipeline_id}[-{agent_id}]/{repo_name}"
  },
  "gates": {
    "preset": "full_auto",
    "add": [],
    "remove": []
  },
  "escalation_policy": "gradient",
  "autonomy": {
    "refiner": "ask_freely",
    "designer": "lean_ask",
    "implementer": "lean_decide",
    "code_reviewer": "decide",
    "documenter": "decide",
    "documentation_reviewer": "decide",
    "submitter": "full",
    "pr_shepherd": "decide"
  },
  "loop_limits": {
    "l1": 3,
    "l3": 3,
    "escalations": 2,
    "post_pr": 5
  },
  "implementer": {
    "inner_loop": { "max_iterations": 20 },
    "tdd": "required_when_possible"
  },
  "checks": {
    "build": "bazel build //src/RayTracingWeekend:RayTracingWeekend",
    "test": null,
    "static": ["clang-format --dry-run -Werror", "clang-tidy"]
  },
  "submitter": { "single_commit": true },
  "pr_shepherd": { "enabled": true },
  "documenter": { "skip_allowed": true },
  "decision_journal": { "in_pr_body": true },
  "budget": { "tokens": null, "usd": null, "warn_ratio": 0.8 },
  "model": { "default": "inherit" },
  "ticketing": {
    "system": "none",
    "jira": { "url": null, "project": null },
    "status_mapping": { "start": "In Progress", "pr": "In Review", "merged": "Done" },
    "post_report": true,
    "sync_spec": true,
    "create_if_missing": "prompt"
  }
}
